# Variables pour le formulaire de contact (envoi via Resend).
#
# En DÉVELOPPEMENT (npm run dev) : copiez ce fichier en `.env` et renseignez les valeurs.
# En PRODUCTION (Cloudflare) : ne PAS mettre la clé ici. Utilisez un secret Wrangler :
#     npx wrangler secret put RESEND_API_KEY
#   et déclarez CONTACT_TO / CONTACT_FROM dans wrangler.jsonc (section "vars").

# Clé API Resend (https://resend.com/api-keys). SECRET — ne jamais committer.
RESEND_API_KEY=

# Destinataire des demandes (repli : thirionexpertise@gmail.com si non défini).
CONTACT_TO=thirionexpertise@gmail.com

# Expéditeur — doit appartenir à un domaine vérifié dans Resend.
CONTACT_FROM=Thirion Expertise <contact@thirion-expertise.fr>
