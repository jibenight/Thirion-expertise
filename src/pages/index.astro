---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CtaBand from '../components/CtaBand.astro';
import HeroSlider from '../components/HeroSlider.astro';

const heroSlides = [
  { src: '/images/hero-architecture.jpg', alt: 'Architecture contemporaine — expertise immobilière' },
  { src: '/images/hero-villa.jpg', alt: 'Villa résidentielle — expertise immobilière et foncière' },
  { src: '/images/hero-architecture-courbes.jpg', alt: 'Façade contemporaine — expertise du bâti' },
  { src: '/images/hero-immeuble.jpg', alt: 'Immeuble moderne — expertise commerciale' },
];
---
<Layout title="Accueil — THIRION EXPERTISE" description="THIRION EXPERTISE s'engage pour les particuliers, professionnels, entreprises, assurés et permet à chaque client de prendre une décision éclairée et sécurisée.">
  <main class="relative">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 right-6 hidden w-px bg-brand-line/60 md:block lg:right-10"
    ></div>

    <section class="relative overflow-hidden bg-brand-soft">
      <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
        <div data-reveal>
          <h1 class="font-serif text-3xl leading-snug text-brand md:text-4xl">
            <span class="font-semibold">THIRION EXPERTISE</span> s'engage pour les particuliers, professionnels, entreprises, assurés et permet à chaque client de prendre une décision éclairée et sécurisée.
          </h1>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/contact/"
              class="motion-button inline-flex items-center rounded-md bg-brand px-5 py-3 text-sm font-medium text-white transition hover:bg-brand/90"
            >
              <span class="relative z-10">Prendre rendez-vous</span>
            </a>
            <a
              href="/specialite/"
              class="motion-button inline-flex items-center rounded-md border border-brand/30 bg-white/70 px-5 py-3 text-sm font-medium text-brand transition hover:bg-white"
            >
              <span class="relative z-10">Nos spécialités</span>
            </a>
          </div>
        </div>
        <div class="relative" data-reveal="right" data-delay="1">
          <HeroSlider slides={heroSlides} interval={4000} />
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-10 md:grid-cols-3">
        <div class="motion-card flex flex-col items-center rounded-lg p-4 text-center" data-reveal data-delay="1">
          <div class="motion-icon flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="houseHands" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-xl font-semibold text-brand">
            Expertise foncière, immobilière et commerciale
          </h3>
        </div>
        <div class="motion-card flex flex-col items-center rounded-lg p-4 text-center md:border-l md:border-brand-line/20" data-reveal data-delay="2">
          <div class="motion-icon flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="houseCrack" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-xl font-semibold text-brand">
            Expertise préalable et après sinistre
          </h3>
        </div>
        <div class="motion-card flex flex-col items-center rounded-lg p-4 text-center md:border-l md:border-brand-line/20" data-reveal data-delay="3">
          <div class="motion-icon flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="users" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-xl font-semibold text-brand">
            Expertise conjointe dossiers spéciaux
          </h3>
        </div>
      </div>
    </section>

    <section class="bg-brand-soft/60">
      <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-[auto_1fr]">
        <div class="motion-icon flex h-32 w-32 items-center justify-center rounded-full bg-white shadow-sm" data-reveal="scale">
          <Icon name="badgeCheck" class="h-14 w-14 stroke-[1.5] text-brand" />
        </div>
        <div data-reveal="right" data-delay="1">
          <h2 class="font-serif text-3xl text-brand md:text-4xl">
            Pourquoi choisir <span class="font-semibold">THIRION EXPERTISE</span> ?
          </h2>
          <ul class="mt-6 space-y-3 text-base">
            {['Expérience reconnue', 'Expertise claire et argumentée', 'Disponibilité pour nos clients'].map((text) => (
              <li class="flex items-center gap-3">
                <Icon name="checkCircle" class="h-5 w-5 shrink-0 text-brand" />
                <span>{text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-[auto_1fr]">
      <div class="motion-icon flex h-32 w-32 items-center justify-center rounded-full bg-brand-soft" data-reveal="scale">
        <Icon name="handshake" class="h-14 w-14 stroke-[1.5] text-brand" />
      </div>
      <div data-reveal="right" data-delay="1">
        <h2 class="font-serif text-3xl text-brand md:text-4xl">Nos <span class="font-semibold">engagements</span></h2>
        <ul class="mt-6 space-y-3 text-base">
          {['Analyse objective', 'Méthodologie structurée', 'Accompagnement dans les situations sensibles et complexes'].map((text) => (
            <li class="flex items-center gap-3">
              <Icon name="checkCircle" class="h-5 w-5 shrink-0 text-brand" />
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="font-serif text-3xl text-brand md:text-4xl" data-reveal>
        Notre <span class="font-semibold">démarche</span>
      </h2>
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {[
          { n: '1', title: 'Prise de contact', body: "Nous échangeons sur votre dossier afin de définir ensemble la mission la plus adaptée à votre situation." },
          { n: '2', title: 'Expertise', body: "Analyse objective et méthodologie structurée, en expertise amiable unilatérale ou contradictoire." },
          { n: '3', title: 'Rapport argumenté', body: "Un rapport clair et argumenté pour prendre une décision éclairée et sécurisée." },
        ].map((step, index) => (
          <div class="motion-card rounded-r-lg border-l-2 border-brand/70 py-2 pl-6" data-reveal data-delay={index + 1}>
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-soft font-serif text-xl font-semibold text-brand">
              {step.n}
            </div>
            <h3 class="mt-4 font-serif text-xl font-semibold text-brand">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-foreground/80">{step.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-brand-soft/60">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="font-serif text-3xl text-brand md:text-4xl" data-reveal>
          Zone d'intervention <span class="font-semibold">THIRION EXPERTISE</span>
        </h2>
        <div class="mt-10 grid items-center gap-10 md:grid-cols-2">
          <div class="space-y-4">
            {[
              { title: "Départements du ressort de la Cour d'Appel de Nîmes", deps: 'Ardèche, Gard, Lozère, Vaucluse' },
              { title: 'Départements limitrophes', deps: 'Aveyron, Bouches-du-Rhône, Drôme, Isère…' },
              { title: 'Autres départements', deps: 'Alpes de Haute-Provence, Var…' },
            ].map((zone, index) => (
              <div class="flex gap-4 rounded-xl border border-brand/10 bg-white p-5 shadow-sm" data-reveal data-delay={index + 1}>
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-soft text-brand">
                  <Icon name="mapPin" class="h-5 w-5" />
                </span>
                <div>
                  <p class="font-serif text-lg font-semibold text-brand">{zone.title}</p>
                  <p class="mt-1 text-sm leading-relaxed text-foreground/70">{zone.deps}</p>
                </div>
              </div>
            ))}
          </div>
          <figure class="motion-image w-full" data-reveal="right" data-delay="2">
            <img
              src="/images/carte-intervention.png"
              alt="Carte des départements d'intervention de THIRION EXPERTISE"
              width="1349"
              height="1166"
              loading="lazy"
              class="h-auto w-full object-contain"
            />
          </figure>
        </div>
      </div>
    </section>
  </main>
  <CtaBand slot="prefooter" />
</Layout>
