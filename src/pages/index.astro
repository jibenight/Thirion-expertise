---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout title="Accueil — THIRION EXPERTISE" description="THIRION EXPERTISE s'engage pour les particuliers, professionnels, entreprises, assurés et permet à chaque client de prendre une décision éclairée et sécurisée.">
  <main class="relative">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 right-6 hidden w-px bg-brand-line/60 md:block lg:right-10"
    ></div>

    <section class="relative overflow-hidden bg-brand-soft">
      <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
        <div data-reveal>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-brand">
            Cabinet d'expertise — Nîmes
          </p>
          <h1 class="font-serif text-4xl leading-tight text-brand md:text-5xl">
            <span class="font-semibold">THIRION EXPERTISE</span> s'engage pour les particuliers, professionnels, entreprises, assurés et permet à chaque client de prendre une décision éclairée et sécurisée.
          </h1>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/contact/"
              class="motion-button inline-flex items-center rounded-md bg-brand px-5 py-3 text-sm font-medium text-white transition hover:bg-brand/90"
            >
              <span class="relative z-10">Prendre rendez-vous</span>
            </a>
            <a
              href="/specialite/"
              class="motion-button inline-flex items-center rounded-md border border-brand/30 px-5 py-3 text-sm font-medium text-brand transition hover:bg-white"
            >
              <span class="relative z-10">Découvrir nos spécialités</span>
            </a>
          </div>
        </div>
        <div class="relative" data-reveal="right" data-delay="1">
          <div class="motion-image relative overflow-hidden rounded-lg shadow-xl">
            <img
              src="/images/hero-architecture.jpg"
              alt="Architecture contemporaine — expertise immobilière"
              width="1600"
              height="1000"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-10 md:grid-cols-3">
        <div class="motion-card motion-card--small flex flex-col items-center rounded-lg p-4 text-center" data-reveal data-delay="1">
          <div class="motion-icon motion-float flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="home" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-lg font-semibold text-brand">
            Expertise foncière, immobilière et commerciale
          </h3>
        </div>
        <div class="motion-card motion-card--small flex flex-col items-center rounded-lg p-4 text-center" data-reveal data-delay="2">
          <div class="motion-icon motion-float flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="housePlus" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-lg font-semibold text-brand">
            Expertise préalable et après sinistre
          </h3>
        </div>
        <div class="motion-card motion-card--small flex flex-col items-center rounded-lg p-4 text-center" data-reveal data-delay="3">
          <div class="motion-icon motion-float flex h-28 w-28 items-center justify-center rounded-full bg-brand-soft">
            <Icon name="users" class="h-12 w-12 stroke-[1.5] text-brand" />
          </div>
          <h3 class="mt-6 max-w-xs font-serif text-lg font-semibold text-brand">
            Expertise conjointe dossiers spéciaux
          </h3>
        </div>
      </div>
    </section>

    <section class="bg-brand-soft/60">
      <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-[auto_1fr]">
        <div class="motion-icon motion-float flex h-32 w-32 items-center justify-center rounded-full bg-white shadow-sm" data-reveal="scale">
          <Icon name="badgeCheck" class="h-14 w-14 stroke-[1.5] text-brand" />
        </div>
        <div data-reveal="right" data-delay="1">
          <h2 class="font-serif text-3xl text-brand md:text-4xl">
            Pourquoi choisir <span class="font-semibold">THIRION EXPERTISE</span> ?
          </h2>
          <ul class="mt-6 space-y-3 text-base">
            {['Expérience reconnue', 'Expertise claire et argumentée', 'Disponibilité pour nos clients'].map((text) => (
              <li class="flex items-center gap-3">
                <Icon name="checkCircle" class="h-5 w-5 shrink-0 text-brand" />
                <span>{text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-[auto_1fr]">
      <div class="motion-icon motion-float flex h-32 w-32 items-center justify-center rounded-full bg-brand-soft" data-reveal="scale">
        <Icon name="handshake" class="h-14 w-14 stroke-[1.5] text-brand" />
      </div>
      <div data-reveal="right" data-delay="1">
        <h2 class="font-serif text-3xl font-semibold text-brand md:text-4xl">Nos engagements</h2>
        <ul class="mt-6 space-y-3 text-base">
          {['Analyse objective', 'Méthodologie structurée', 'Accompagnement dans les situations sensibles et complexes'].map((text) => (
            <li class="flex items-center gap-3">
              <Icon name="checkCircle" class="h-5 w-5 shrink-0 text-brand" />
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="bg-brand-soft/60">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="font-serif text-4xl text-brand md:text-5xl" data-reveal>
          Zone d'intervention <span class="font-semibold">THIRION EXPERTISE</span>
        </h2>
        <div class="mt-8 grid items-center gap-8 md:grid-cols-2">
          <ul class="flex flex-col justify-center gap-12 text-base md:min-h-full md:py-10 md:text-lg">
            <li class="relative pl-8 leading-relaxed" data-reveal data-delay="1">
              <span aria-hidden="true" class="absolute left-0 top-3 h-3 w-3 rounded-full bg-brand"></span>
              <span class="text-lg font-semibold text-brand md:text-xl">Départements du ressort</span><br />
              <span class="text-base text-foreground/80 md:text-lg">de la Cour d'Appel de Nîmes (Ardèche, Gard, Lozère, Vaucluse)</span>
            </li>
            <li class="relative pl-8 leading-relaxed" data-reveal data-delay="2">
              <span aria-hidden="true" class="absolute left-0 top-3 h-3 w-3 rounded-full bg-brand"></span>
              <span class="text-lg font-semibold text-brand md:text-xl">Départements limitrophes</span><br />
              <span class="text-base text-foreground/80 md:text-lg">Aveyron, Bouches-du-Rhône, Drôme, Isère…</span>
            </li>
            <li class="relative pl-8 leading-relaxed" data-reveal data-delay="3">
              <span aria-hidden="true" class="absolute left-0 top-3 h-3 w-3 rounded-full bg-brand"></span>
              <span class="text-lg font-semibold text-brand md:text-xl">Autres départements</span><br />
              <span class="text-base text-foreground/80 md:text-lg">Alpes de Haute-Provence, Var…</span>
            </li>
          </ul>
          <figure class="motion-image overflow-hidden rounded-lg bg-white/70 p-2" data-reveal="right" data-delay="2">
            <img
              src="/images/carte-intervention-site.jpg"
              alt="Carte des départements d'intervention de THIRION EXPERTISE"
              width="555"
              height="480"
              loading="lazy"
              class="h-auto w-full object-contain"
            />
          </figure>
        </div>
      </div>
    </section>
  </main>
</Layout>
