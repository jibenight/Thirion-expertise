---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/PageShell.astro';
import Icon from '../components/Icon.astro';
import { reader, getParametres, telHref } from '../lib/content';

const page = await reader.singletons.contact.read();
const params = await getParametres();
const tel = telHref(params.telephone);
---
<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <PageShell eyebrow="Contact" title="Contact">
    {page?.image && (
      <figure class="motion-image mb-10 overflow-hidden rounded-lg shadow-md" data-reveal>
        <img src={page.image} alt="" loading="lazy" class="max-h-80 w-full object-cover" />
      </figure>
    )}
    <div class="max-w-2xl" data-reveal data-delay="1">
      <h2 class="font-serif text-2xl font-semibold text-brand">
        {page?.introTitre}
      </h2>
      <p class="mt-4 text-foreground/80">
        {page?.introTexte}
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[1.2fr_1fr]">
      <form
        id="contact-form"
        method="post"
        action="/api/contact"
        class="motion-card rounded-lg border border-brand/15 bg-brand-soft/40 p-6 md:p-8"
        data-reveal
      >
        <h3 class="font-serif text-xl font-semibold text-brand">Formulaire de contact</h3>
        <div class="mt-6 h-px w-16 bg-brand/40"></div>
        <div class="mt-6 space-y-5">
          <div class="hidden" aria-hidden="true">
            <label for="company">Ne pas remplir</label>
            <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-brand" for="name">Nom prénom</label>
            <input id="name" name="name" required class="w-full rounded-md border border-brand/20 bg-white px-3 py-2 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/20" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-brand" for="phone">Téléphone</label>
            <input id="phone" name="phone" type="tel" class="w-full rounded-md border border-brand/20 bg-white px-3 py-2 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/20" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-brand" for="email">Adresse mail</label>
            <input id="email" name="email" type="email" required class="w-full rounded-md border border-brand/20 bg-white px-3 py-2 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/20" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-brand" for="subject">Objet de votre demande</label>
            <input id="subject" name="subject" required class="w-full rounded-md border border-brand/20 bg-white px-3 py-2 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/20" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-brand" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full rounded-md border border-brand/20 bg-white px-3 py-2 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/20"
            ></textarea>
          </div>
          <button
            type="submit"
            class="motion-button mt-2 inline-flex items-center justify-center rounded-md bg-brand px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-brand/90 disabled:cursor-not-allowed disabled:opacity-60"
          >
            <span class="relative z-10">Envoyer ma demande</span>
          </button>
          <p id="form-success" class="hidden rounded-md bg-brand/10 px-4 py-3 text-sm text-brand" role="status">
            Merci, votre demande a bien été envoyée. Nous vous répondrons dans les meilleurs délais.
          </p>
          <p id="form-error" class="hidden rounded-md bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></p>
        </div>
      </form>

      <aside class="motion-card rounded-lg border border-brand/15 bg-white p-6 md:p-8" data-reveal="right" data-delay="1">
        <h3 class="font-serif text-xl font-semibold text-brand">Coordonnées du cabinet</h3>
        <div class="mt-4 h-px w-16 bg-brand/40"></div>
        <p class="mt-6 font-serif text-xl font-semibold text-brand">THIRION EXPERTISE</p>
        <ul class="mt-6 space-y-5 text-sm">
          <li class="flex gap-3">
            <Icon name="mapPin" class="mt-0.5 h-5 w-5 shrink-0 text-brand" />
            <div>
              {params.adresseLigne1}<br />
              {params.adresseLigne2}
              <div class="mt-1 italic text-brand/80">{params.adresseNote}</div>
            </div>
          </li>
          <li>
            <a href={`tel:${tel}`} class="flex items-center gap-3 hover:text-brand">
              <Icon name="phone" class="h-5 w-5 text-brand" />
              <span class="font-semibold">Téléphone : {params.telephone}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${params.email}`} class="flex items-center gap-3 break-all hover:text-brand">
              <Icon name="mail" class="h-5 w-5 shrink-0 text-brand" />
              mail : {params.email}
            </a>
          </li>
        </ul>
        {params.linkedin && (
          <div class="mt-6 border-t border-border pt-6">
            <p class="text-sm font-semibold text-brand">Retrouvez-nous sur LinkedIn</p>
            <a
              href={params.linkedin}
              target="_blank"
              rel="noreferrer noopener"
              class="mt-3 inline-flex h-10 w-10 items-center justify-center rounded-md bg-brand text-white transition hover:bg-brand/90"
              aria-label="LinkedIn"
            >
              <Icon name="linkedin" class="h-5 w-5" />
            </a>
          </div>
        )}
      </aside>
    </div>
  </PageShell>
</Layout>

<script>
  const form = document.querySelector('#contact-form') as HTMLFormElement | null;
  const success = document.querySelector('#form-success');
  const error = document.querySelector('#form-error');
  const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const buttonLabel = button?.querySelector('span');
  const defaultLabel = buttonLabel?.textContent ?? 'Envoyer ma demande';

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    success?.classList.add('hidden');
    error?.classList.add('hidden');

    if (button) button.disabled = true;
    if (buttonLabel) buttonLabel.textContent = 'Envoi en cours…';

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const result = await response.json().catch(() => ({ ok: false }));

      if (response.ok && result.ok) {
        form.reset();
        success?.classList.remove('hidden');
      } else {
        if (error) {
          error.textContent = result.error ?? "L'envoi a échoué, réessayez plus tard.";
          error.classList.remove('hidden');
        }
      }
    } catch {
      if (error) {
        error.textContent = "L'envoi a échoué, vérifiez votre connexion et réessayez.";
        error.classList.remove('hidden');
      }
    } finally {
      if (button) button.disabled = false;
      if (buttonLabel) buttonLabel.textContent = defaultLabel;
    }
  });
</script>
