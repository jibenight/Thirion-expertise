---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/PageShell.astro';
import { reader, getParametres, telHref } from '../lib/content';

const page = await reader.singletons.mentionsLegales.read();
const params = await getParametres();
const tel = telHref(params.telephone);
---
<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <PageShell eyebrow="Informations" title="Mentions légales">
    <div class="max-w-3xl space-y-10">
      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Éditeur du site</h2>
        <div class="mt-3 space-y-1 leading-relaxed text-foreground/80">
          <p><span class="font-semibold text-brand">THIRION EXPERTISE</span></p>
          <p>{params.adresseLigne1} — {params.adresseLigne2}</p>
          <p>
            Téléphone :{' '}
            <a href={`tel:${tel}`} class="motion-link text-brand hover:underline">{params.telephone}</a>
          </p>
          <p>
            E-mail :{' '}
            <a href={`mailto:${params.email}`} class="motion-link text-brand hover:underline">{params.email}</a>
          </p>
          {page?.editeurComplement && (
            <p class="pt-2">
              <span class="rounded bg-brand-soft px-1.5 py-0.5 text-sm font-medium text-brand/80">
                {page.editeurComplement}
              </span>
            </p>
          )}
        </div>
      </section>

      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Directeur de la publication</h2>
        <p class="mt-3 leading-relaxed text-foreground/80">{page?.directeur}</p>
      </section>

      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Hébergement</h2>
        <p class="mt-3 leading-relaxed text-foreground/80">
          <span class="rounded bg-brand-soft px-1.5 py-0.5 text-sm font-medium text-brand/80">
            {page?.hebergement}
          </span>
        </p>
      </section>

      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Propriété intellectuelle</h2>
        <p class="mt-3 leading-relaxed text-foreground/80">
          {page?.proprieteIntellectuelle}
        </p>
      </section>

      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Données personnelles</h2>
        <p class="mt-3 leading-relaxed text-foreground/80">
          {page?.donneesPersonnelles}
        </p>
      </section>

      <section data-reveal>
        <h2 class="font-serif text-2xl font-semibold text-brand">Cookies</h2>
        <p class="mt-3 leading-relaxed text-foreground/80">
          {page?.cookies}
        </p>
      </section>
    </div>
  </PageShell>
</Layout>
