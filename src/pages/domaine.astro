---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/PageShell.astro';
import CtaBand from '../components/CtaBand.astro';
import { reader } from '../lib/content';

const page = await reader.singletons.domaine.read();
const domaines = page?.items ?? [];
---
<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <PageShell eyebrow={page?.eyebrow} title={page?.titre}>
    <p class="max-w-3xl font-serif text-2xl leading-snug text-brand" data-reveal data-delay="1">
      {page?.intro}
    </p>
    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {domaines.map((d, index) => (
        <article class="motion-card rounded-r-lg border-l-2 border-brand/70 py-4 pl-6" data-reveal data-delay={(index % 3) + 1}>
          <h2 class="font-serif text-2xl font-semibold text-brand">{d.titre}</h2>
          <p class="mt-2 leading-relaxed text-foreground/80">{d.corps}</p>
        </article>
      ))}
    </div>
  </PageShell>
  <CtaBand slot="prefooter" />
</Layout>
