---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/PageShell.astro';
import Icon from '../components/Icon.astro';
import CtaBand from '../components/CtaBand.astro';
import { reader } from '../lib/content';

const page = await reader.singletons.specialite.read();
const items = page?.items ?? [];
---
<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <PageShell eyebrow={page?.eyebrow} title={page?.titre}>
    {page?.image && (
      <figure class="motion-image mb-10 overflow-hidden rounded-lg shadow-md" data-reveal>
        <img src={page.image} alt="" loading="lazy" class="max-h-80 w-full object-cover" />
      </figure>
    )}
    <div class="divide-y divide-border">
      {items.map((item, index) => (
        <article class="motion-card grid gap-6 rounded-lg py-10 md:grid-cols-[auto_1fr] md:gap-10" data-reveal data-delay={(index % 3) + 1}>
          <div class="motion-icon flex h-24 w-24 items-center justify-center rounded-full bg-brand-soft">
            <Icon name={item.icon} class="h-10 w-10 stroke-[1.5] text-brand" />
          </div>
          <div class="max-w-2xl">
            <h2 class="font-serif text-2xl font-semibold text-brand">{item.titre}</h2>
            <p class="mt-2 italic text-brand/80">{item.sousTitre}</p>
            <p class="mt-4 leading-relaxed text-foreground/80">{item.corps}</p>
          </div>
        </article>
      ))}
    </div>
  </PageShell>
  <CtaBand slot="prefooter" />
</Layout>
