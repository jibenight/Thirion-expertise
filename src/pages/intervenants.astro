---
import Layout from '../layouts/Layout.astro';
import PageShell from '../components/PageShell.astro';
import Icon from '../components/Icon.astro';
import CtaBand from '../components/CtaBand.astro';
import { reader } from '../lib/content';

const page = await reader.singletons.intervenants.read();
const people = page?.personnes ?? [];
---
<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <PageShell eyebrow={page?.eyebrow} title={page?.titre}>
    <div class="space-y-16">
      {people.map((person, index) => (
        <>
          {index > 0 && <div class="h-px bg-border"></div>}
          <article class="grid gap-8 md:grid-cols-[280px_1fr] md:gap-12" data-reveal>
            <div class="motion-image overflow-hidden rounded-lg shadow-md">
              <img
                src={person.photo}
                alt={person.nom}
                loading="lazy"
                width="800"
                height="1000"
                class="h-full w-full object-cover"
              />
            </div>
            <div data-reveal="right" data-delay="1">
              <h2 class="font-serif text-2xl font-semibold text-brand">{person.nom}</h2>
              <ul class="mt-4 space-y-1 leading-relaxed text-foreground/85">
                {person.roles.map((item) => <li>{item}</li>)}
              </ul>
              <blockquote class="motion-card relative mt-6 max-w-md rounded-md border border-brand/15 bg-brand-soft/60 p-5 pl-12">
                <Icon name="quote" class="absolute left-4 top-4 h-6 w-6 text-brand" />
                <p class="font-serif italic text-brand">« {person.citation} »</p>
              </blockquote>
            </div>
          </article>
        </>
      ))}
    </div>
  </PageShell>
  <CtaBand slot="prefooter" />
</Layout>
