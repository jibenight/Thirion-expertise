---
const { title, eyebrow } = Astro.props;
---
<main class="relative min-h-[60vh]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-y-0 right-6 hidden w-px bg-brand-line/60 md:block lg:right-10"
  ></div>
  <div class="mx-auto max-w-6xl px-6 pb-16 pt-10 md:pt-14">
    {title && (
      <header class="mb-10" data-reveal>
        {eyebrow && (
          <div class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-brand">
            {eyebrow}
          </div>
        )}
        <h1 class="font-serif text-4xl text-brand md:text-5xl">{title}</h1>
        <div class="mt-3 h-px w-20 bg-brand"></div>
      </header>
    )}
    <slot />
  </div>
</main>
