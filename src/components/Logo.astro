---
// Logo « nombre d'or » du cabinet : rectangle en subdivisions dorées
// traversé par le trait bleu vertical (repris à droite sur toutes les pages).
const { size = 38 } = Astro.props;
const w = size;
const h = Math.round(size * 1.538);
---
<svg width={w} height={h} viewBox="0 0 104 160" fill="none" role="img" aria-label="THIRION EXPERTISE">
  <rect x="2" y="2" width="100" height="156" fill="white" stroke="var(--brand)" stroke-width="2.4" />
  <line x1="2" y1="47" x2="102" y2="47" stroke="var(--brand)" stroke-width="1.3" />
  <line x1="66" y1="2" x2="66" y2="47" stroke="var(--brand)" stroke-width="1.3" />
  <line x1="66" y1="30" x2="102" y2="30" stroke="var(--brand)" stroke-width="1.3" />
  <line x1="52" y1="2" x2="52" y2="158" stroke="var(--brand-line)" stroke-width="3" />
</svg>
